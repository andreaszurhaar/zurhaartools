</Layout>

<script>
  function activateProduct(productId) {
    document.querySelectorAll('[data-product-section]').forEach(section => {
      section.classList.toggle('hidden', section.dataset.productSection !== productId);
    });
    document.querySelectorAll('.product-tab').forEach(tab => {
      const isActive = tab.dataset.product === productId;
      if (isActive) {
        tab.className = 'product-tab px-4 py-2 text-sm font-medium rounded-full transition-all cursor-pointer bg-gradient-to-r from-primary to-accent text-white';
      } else {
        tab.className = 'product-tab px-4 py-2 text-sm font-medium rounded-full transition-all cursor-pointer text-text-muted bg-surface-raised border border-border hover:border-border-hover';
      }
    });
  }

  document.querySelectorAll('.product-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const productId = tab.dataset.product;
      history.replaceState(null, '', '#' + productId);
      activateProduct(productId);
    });
  });

  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.slice(1);
    if (hash && document.querySelector(`[data-product-section="${hash}"]`)) {
      activateProduct(hash);
    }
  });

  const initialHash = window.location.hash.slice(1);
  const validProduct = initialHash && document.querySelector(`[data-product-section="${initialHash}"]`);
  activateProduct(validProduct ? initialHash : 'job-red-flag-detector');
</script>
