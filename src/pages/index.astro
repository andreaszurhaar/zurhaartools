---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-6">
        AI-powered tools that
        <span class="text-primary">save you time</span>
      </h1>
      <p class="text-lg text-text-muted mb-8 max-w-2xl">
        Browser extensions, scripts, and digital tools — built with AI to automate the boring stuff. New tools added regularly.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/products"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-primary hover:bg-primary-dark rounded-lg transition-colors"
        >
          Browse Products
        </a>
        <a
          href="/about"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-text border border-border hover:bg-gray-50 rounded-lg transition-colors"
        >
          About Me
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Latest Products</h2>
      <a href="/products" class="text-sm text-primary hover:text-primary-dark transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard
        title="ToS Scanner"
        description="AI-powered browser extension that scans Terms of Service and Privacy Policies, highlighting dangers in plain language."
        category="extension"
        comingSoon={true}
      />
      <ProductCard
        title="Job Red Flag Detector"
        description="Spots warning signs in job postings — vague salary, unrealistic requirements, toxic culture signals."
        category="extension"
        comingSoon={true}
      />
      <ProductCard
        title="AI Review Summarizer"
        description="Reads hundreds of product or hotel reviews and gives you a 5-bullet summary of pros and cons."
        category="extension"
        comingSoon={true}
      />
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="text-2xl font-bold mb-12 text-center">How it works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-blue-100 text-primary rounded-xl flex items-center justify-center mx-auto mb-4 text-xl font-bold">1</div>
          <h3 class="font-semibold mb-2">Pick a tool</h3>
          <p class="text-sm text-text-muted">Browse the catalog and find something that solves your problem.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-blue-100 text-primary rounded-xl flex items-center justify-center mx-auto mb-4 text-xl font-bold">2</div>
          <h3 class="font-semibold mb-2">Install or download</h3>
          <p class="text-sm text-text-muted">Extensions install in one click. Scripts and templates download instantly.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-blue-100 text-primary rounded-xl flex items-center justify-center mx-auto mb-4 text-xl font-bold">3</div>
          <h3 class="font-semibold mb-2">Save time</h3>
          <p class="text-sm text-text-muted">Let AI do the heavy lifting. Focus on what actually matters.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
