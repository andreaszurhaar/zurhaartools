---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
    <div class="max-w-3xl">
      <p class="text-sm font-medium text-primary-light mb-4 tracking-wide uppercase">Smart Tools & Extensions</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
        Tools that do the
        <span class="bg-gradient-to-r from-primary via-primary-light to-accent bg-clip-text text-transparent">boring stuff</span>
        for you
      </h1>
      <p class="text-lg text-text-muted mb-10 max-w-2xl leading-relaxed">
        Browser extensions, scripts, and digital tools — built to automate what you shouldn't waste time on. New tools added regularly.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/products"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-primary to-accent hover:opacity-90 rounded-lg transition-opacity"
        >
          Browse Products
        </a>
        <a
          href="/about"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-text-muted border border-border hover:border-border-hover hover:text-text rounded-lg transition-all"
        >
          About Me
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Latest Products</h2>
      <a href="/products" class="text-sm text-primary-light hover:text-primary transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProductCard
        title="ToS Scanner"
        description="Browser extension that scans Terms of Service and Privacy Policies, highlighting dangers in plain language."
        category="extension"
        comingSoon={true}
      />
      <ProductCard
        title="Job Red Flag Detector"
        description="Spots warning signs in job postings — vague salary, unrealistic requirements, toxic culture signals."
        category="extension"
        price="From €1.99"
        href="/pricing"
      />
      <ProductCard
        title="AI Review Summarizer"
        description="Reads hundreds of product or hotel reviews and gives you a 5-bullet summary of pros and cons."
        category="extension"
        comingSoon={true}
      />
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="text-2xl font-bold mb-4 text-center">How it works</h2>
      <p class="text-text-muted text-center mb-14 max-w-lg mx-auto">From browsing to using — in seconds.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-14 h-14 bg-gradient-to-br from-primary/20 to-accent/20 border border-primary/20 text-primary-light rounded-xl flex items-center justify-center mx-auto mb-5 text-lg font-bold group-hover:from-primary/30 group-hover:to-accent/30 transition-all">1</div>
          <h3 class="font-semibold mb-2">Pick a tool</h3>
          <p class="text-sm text-text-muted leading-relaxed">Browse the catalog and find something that solves your problem.</p>
        </div>
        <div class="text-center group">
          <div class="w-14 h-14 bg-gradient-to-br from-primary/20 to-accent/20 border border-primary/20 text-primary-light rounded-xl flex items-center justify-center mx-auto mb-5 text-lg font-bold group-hover:from-primary/30 group-hover:to-accent/30 transition-all">2</div>
          <h3 class="font-semibold mb-2">Get it instantly</h3>
          <p class="text-sm text-text-muted leading-relaxed">One click to install extensions or download scripts and templates.</p>
        </div>
        <div class="text-center group">
          <div class="w-14 h-14 bg-gradient-to-br from-primary/20 to-accent/20 border border-primary/20 text-primary-light rounded-xl flex items-center justify-center mx-auto mb-5 text-lg font-bold group-hover:from-primary/30 group-hover:to-accent/30 transition-all">3</div>
          <h3 class="font-semibold mb-2">Save time</h3>
          <p class="text-sm text-text-muted leading-relaxed">Let the tools do the heavy lifting. Focus on what actually matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">New tools every month</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">I'm constantly building new tools and extensions. Check back often or follow along on GitHub.</p>
      <a
        href="https://github.com/andreaszurhaar"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-primary to-accent hover:opacity-90 rounded-lg transition-opacity"
      >
        Follow on GitHub
      </a>
    </div>
  </section>
</Layout>
