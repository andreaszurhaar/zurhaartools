---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recover License Key — Zurhaar Tools" description="Recover your Zurhaar Tools license key by email.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-md mx-auto text-center">
      <h1 class="text-3xl font-bold tracking-tight mb-4">Recover your license key</h1>
      <p class="text-text-muted mb-8">
        Enter the email you used when you purchased and we'll send your license key.
      </p>

      <div id="form-state">
        <form id="recover-form" class="space-y-4">
          <input
            type="email"
            id="email-input"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 bg-card border border-border rounded-lg text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors"
          />
          <button
            type="submit"
            id="submit-btn"
            class="w-full inline-flex items-center justify-center px-4 py-3 text-sm font-medium text-white bg-gradient-to-r from-primary to-accent hover:opacity-90 rounded-lg transition-opacity"
          >
            Send recovery email
          </button>
        </form>
      </div>

      <div id="success-state" class="hidden">
        <div class="w-16 h-16 bg-green-500/20 border border-green-500/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-green-400 text-2xl">&#10003;</span>
        </div>
        <p class="text-text-muted">
          If an account exists with that email, we've sent your license key. Check your inbox.
        </p>
      </div>

      <div id="error-state" class="hidden">
        <p class="text-red-400 mb-4">Something went wrong. Please try again.</p>
        <button
          id="retry-btn"
          class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-text-muted border border-border hover:border-border-hover hover:text-text rounded-lg transition-all"
        >
          Try again
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('recover-form');
  const emailInput = document.getElementById('email-input');
  const submitBtn = document.getElementById('submit-btn');
  const formState = document.getElementById('form-state');
  const successState = document.getElementById('success-state');
  const errorState = document.getElementById('error-state');
  const retryBtn = document.getElementById('retry-btn');

  function showState(state) {
    formState.classList.toggle('hidden', state !== 'form');
    successState.classList.toggle('hidden', state !== 'success');
    errorState.classList.toggle('hidden', state !== 'error');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    try {
      const res = await fetch('https://zurhaartools-api.andreaszurhaar.workers.dev/api/recover', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok || res.status === 404) {
        showState('success');
      } else {
        showState('error');
      }
    } catch {
      showState('error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send recovery email';
    }
  });

  retryBtn.addEventListener('click', () => {
    showState('form');
  });
</script>
