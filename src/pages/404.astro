---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Zurhaar Tools" description="The page you're looking for doesn't exist.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-6xl font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent mb-6">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Page not found</h1>
      <p class="text-text-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-primary to-accent hover:opacity-90 rounded-lg transition-opacity"
        >
          Back to Home
        </a>
        <a
          href="/products"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-text-muted border border-border hover:border-border-hover hover:text-text rounded-lg transition-all"
        >
          Browse Products
        </a>
      </div>
    </div>
  </section>
</Layout>
