---
interface Props {
  title: string;
  description: string;
  category: 'extension' | 'script' | 'template' | 'tool' | 'app';
  price?: string;
  href?: string;
  comingSoon?: boolean;
}

const { title, description, category, price, href, comingSoon = false } = Astro.props;

const categoryLabels: Record<string, { label: string; color: string }> = {
  extension: { label: 'Extension', color: 'bg-blue-100 text-blue-700' },
  script: { label: 'Script', color: 'bg-green-100 text-green-700' },
  template: { label: 'Template', color: 'bg-purple-100 text-purple-700' },
  tool: { label: 'Tool', color: 'bg-orange-100 text-orange-700' },
  app: { label: 'App', color: 'bg-pink-100 text-pink-700' },
};

const cat = categoryLabels[category];
---

<div class="bg-card border border-border rounded-xl p-6 flex flex-col hover:shadow-lg transition-shadow">
  <div class="flex items-center justify-between mb-3">
    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${cat.color}`}>
      {cat.label}
    </span>
    {price && (
      <span class="text-sm font-semibold text-text">{price}</span>
    )}
  </div>
  <h3 class="text-lg font-semibold mb-2">{title}</h3>
  <p class="text-sm text-text-muted flex-1 mb-4">{description}</p>
  {comingSoon ? (
    <span class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-text-muted bg-gray-100 rounded-lg cursor-default">
      Coming Soon
    </span>
  ) : href ? (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-primary hover:bg-primary-dark rounded-lg transition-colors"
    >
      View Product &rarr;
    </a>
  ) : null}
</div>
