---
interface Props {
  title: string;
  description: string;
  category: 'extension' | 'script' | 'template' | 'tool' | 'app';
  price?: string;
  href?: string;
  comingSoon?: boolean;
}

const { title, description, category, price, href, comingSoon = false } = Astro.props;

const categoryLabels: Record<string, { label: string; color: string }> = {
  extension: { label: 'Extension', color: 'bg-orange-500/15 text-orange-400 border border-orange-500/20' },
  script: { label: 'Script', color: 'bg-green-500/15 text-green-400 border border-green-500/20' },
  template: { label: 'Template', color: 'bg-amber-500/15 text-amber-400 border border-amber-500/20' },
  tool: { label: 'Tool', color: 'bg-red-500/15 text-red-400 border border-red-500/20' },
  app: { label: 'App', color: 'bg-yellow-500/15 text-yellow-400 border border-yellow-500/20' },
};

const cat = categoryLabels[category];
---

<div class="group bg-card border border-border rounded-xl p-6 flex flex-col hover:border-border-hover hover:bg-card-hover transition-all duration-300">
  <div class="flex items-center justify-between mb-3">
    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${cat.color}`}>
      {cat.label}
    </span>
    {price && (
      <span class="text-sm font-semibold text-text">{price}</span>
    )}
  </div>
  <h3 class="text-lg font-semibold mb-2 group-hover:text-primary-light transition-colors">{title}</h3>
  <p class="text-sm text-text-muted flex-1 mb-4 leading-relaxed">{description}</p>
  {comingSoon ? (
    <span class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-text-muted bg-surface-raised border border-border rounded-lg cursor-default">
      Coming Soon
    </span>
  ) : href ? (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-primary to-accent hover:opacity-90 rounded-lg transition-opacity"
    >
      Get it &rarr;
    </a>
  ) : null}
</div>
