---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zurhaar Tools — AI-Powered Tools & Extensions',
  description = 'Browser extensions, scripts, and AI-powered tools built to save you time. By Andreas Zurhaar.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-text min-h-screen flex flex-col">
    <nav class="border-b border-border">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight">
          Zurhaar<span class="text-primary">Tools</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="/products" class="text-sm text-text-muted hover:text-text transition-colors">Products</a>
          <a href="/about" class="text-sm text-text-muted hover:text-text transition-colors">About</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-sm text-text-muted">
            &copy; {new Date().getFullYear()} Zurhaar Tools. Built by Andreas Zurhaar.
          </p>
          <div class="flex items-center gap-4">
            <a href="https://github.com/andreaszurhaar" class="text-sm text-text-muted hover:text-text transition-colors">GitHub</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
