---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zurhaar Tools — Smart Tools & Extensions',
  description = 'Browser extensions, scripts, and tools built to save you time. By Andreas Zurhaar.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Zurhaar Tools" />
    <meta property="og:image" content="https://zurhaartools.com/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://zurhaartools.com/og-image.png" />
  </head>
  <body class="bg-surface text-text min-h-screen flex flex-col">
    <!-- Subtle dot grid background -->
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_1px_1px,rgba(249,115,22,0.08)_1px,transparent_0)] bg-[size:32px_32px]"></div>

    <nav class="border-b border-border backdrop-blur-md bg-surface/80 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight">
          Zurhaar<span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Tools</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="/products" class="text-sm text-text-muted hover:text-text transition-colors">Products</a>
          <a href="/about" class="text-sm text-text-muted hover:text-text transition-colors">About</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-sm text-text-muted">
            &copy; {new Date().getFullYear()} Zurhaar Tools. Built by Andreas Zurhaar.
          </p>
          <div class="flex items-center gap-4">
            <a href="/terms" class="text-sm text-text-muted hover:text-text transition-colors">Terms</a>
            <a href="/privacy" class="text-sm text-text-muted hover:text-text transition-colors">Privacy</a>
            <a href="https://github.com/andreaszurhaar" class="text-sm text-text-muted hover:text-text transition-colors">GitHub</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
